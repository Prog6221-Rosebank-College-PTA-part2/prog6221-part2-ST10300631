<Window x:Class="Chatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Chatbot"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="800">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#222222"/>
            <Setter Property="Background" Value="#EEEEEE"/>
            

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}" Padding="15" BorderThickness="5" Margin="0" >
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="Aqua"/>

                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="Green"/>

                </Trigger>
            </Style.Triggers>
            
            
        </Style>
    </Window.Resources>

 
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <MediaElement Grid.Column="1" x:Name="BackgroundVideo" 
              Source="Background/Matrix Raining Code.mp4" 
              LoadedBehavior="Manual" 
              UnloadedBehavior="Manual" 
              Stretch="UniformToFill" 
              IsMuted="True"
              MediaEnded="BackgroundVideo_MediaEnded"/>

        <!-- Your App UI Layer Goes Here -->
        <Grid Background="#55000000">
            <!-- Semitransparent overlay for text legibility -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Welcome to My App" FontSize="32" Foreground="White" FontWeight="Bold"/>
                <Button Content="Get Started" Width="120" Height="40" Margin="10"/>
            </StackPanel>
        </Grid>

        <ListBox Grid.Column="0" SelectionMode="Single" Cursor="Hand" x:Name="navbar" BorderThickness="0" Background="Navy" Padding="5">


            <Button Width="100" Click="HomeButton_Click">
                <StackPanel Orientation="Horizontal">
                    <!-- Text -->
                    <TextBlock Text="Home" >
                           
                    </TextBlock>
                    <!-- Icon: Ensure the image is added to your project and "Build Action" is set to "Resource" -->
                    <TextBlock Text="&#xf015;" FontFamily="./#Font Awesome 7 Free Solid"  VerticalAlignment="Center" Margin="5"/>
                    
                </StackPanel>
            </Button>

            <Button  Width="100" Click="BotButton_Click">
                <StackPanel Orientation="Horizontal">
                    <!-- Text -->
                    <TextBlock Text="ChatBot">
                         
                    </TextBlock> 
                    <!-- Icon: Ensure the image is added to your project and "Build Action" is set to "Resource" -->
                    <TextBlock Text="&#xf4ad;" FontFamily="./#Font Awesome 7 Free Solid"  VerticalAlignment="Center" Margin="5"/>
                   
                </StackPanel>
            </Button >

            <Button  Width="100" Click="GameButton_Click" >
                <StackPanel Orientation="Horizontal">
                    <!-- Text -->
                    <TextBlock Text="Game" />
                    <!-- Icon: Ensure the image is added to your project and "Build Action" is set to "Resource" -->
                    <TextBlock Text="&#xf11b;" FontFamily="./#Font Awesome 7 Free Solid"  VerticalAlignment="Center" Margin="5"/>
                </StackPanel>
            </Button>

            <Button  Width="100" Click="TAssist_Click">
                <StackPanel Orientation="Horizontal">
                    <!-- Text -->
                    <TextBlock Text="Task Assistant" />
                    <!-- Icon: Ensure the image is added to your project and "Build Action" is set to "Resource" -->
                    <TextBlock Text="&#xf05a;" FontFamily="./#Font Awesome 7 Free Solid"  VerticalAlignment="Center" Margin="5"/>
                </StackPanel>
            </Button>

        </ListBox>

        <Frame Grid.Column="1" x:Name="navframe" NavigationUIVisibility="Hidden" Background="#e9ecef"/>

    </Grid>


</Window>
